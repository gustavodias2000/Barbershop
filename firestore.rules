rules_version = '2';

// Regras de segurança do Firestore — Barbershop
// Modelo: cada usuário só acessa os próprios dados; o barbeiro só acessa
// os agendamentos em que é o dono (barbeiroId == seu uid).
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Funções auxiliares ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Verifica no doc de perfil se o usuário logado é do tipo barbeiro
    function isBarbeiro() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == 'barbeiro';
    }

    // ---- Multi-profissional (negócios/equipe) ----
    // O usuário logado é o dono do negócio indicado (papel == 'dono' na
    // subcoleção privada de membros).
    function isDonoDoNegocio(negocioId) {
      return isSignedIn() && negocioId != null
        && exists(/databases/$(database)/documents/negocios/$(negocioId)/membros/$(request.auth.uid))
        && get(/databases/$(database)/documents/negocios/$(negocioId)/membros/$(request.auth.uid)).data.papel == 'dono';
    }

    // O usuário logado é dono do negócio ao qual este barbeiroId pertence
    // (usado quando o doc em questão não é o próprio Barbeiro, ex.: clientes).
    function isDonoDoBarbeiro(barbeiroId) {
      return exists(/databases/$(database)/documents/barbeiros/$(barbeiroId))
        && isDonoDoNegocio(get(/databases/$(database)/documents/barbeiros/$(barbeiroId)).data.get('negocioId', null));
    }

    // ---- Perfis de usuário ----
    match /usuarios/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      // Impede o usuário de trocar o próprio "tipo" (anti-escalonamento de privilégio)
      allow update: if isOwner(uid)
                    && request.resource.data.tipo == resource.data.tipo;
      // LGPD (direito de exclusão): o titular pode apagar o próprio perfil
      allow delete: if isOwner(uid);
    }

    // ---- Barbeiros (vitrine pública para clientes logados) ----
    match /barbeiros/{barbeiroId} {
      allow read:  if isSignedIn();
      // O próprio barbeiro (doc id == uid, profissional solo ou dono de
      // equipe) pode escrever no próprio doc; o dono de um negócio também
      // pode criar/editar os profissionais da própria equipe (que não têm
      // login próprio — ver NegocioRepository).
      allow create: if (isOwner(barbeiroId) && isBarbeiro())
                    || isDonoDoNegocio(request.resource.data.get('negocioId', null));
      allow update, delete: if (isOwner(barbeiroId) && isBarbeiro())
                    || isDonoDoNegocio(resource.data.get('negocioId', null));

      // ---- Agenda de clientes do barbeiro (cadastro manual/importado) ----
      // Privada: só o próprio barbeiro dono (ou o dono do negócio, se este
      // profissional faz parte de uma equipe) acessa.
      match /clientes/{clienteId} {
        allow read, write: if (isOwner(barbeiroId) && isBarbeiro()) || isDonoDoBarbeiro(barbeiroId);
      }
    }

    // ---- Negócios (equipe multi-profissional) ----
    match /negocios/{negocioId} {
      // A 2ª condição (resource.data.donoUid) é necessária para a QUERY
      // getNegocioPorDono() (where donoUid == uid, sem conhecer o id do
      // negócio de antemão): o Firestore só autoriza uma query de lista se
      // a regra puder ser provada usando o próprio filtro da query. Como
      // isDonoDoNegocio() depende de uma leitura em subcoleção (membros)
      // sem relação direta com o campo filtrado (donoUid), o Firestore não
      // consegue provar a regra e nega a query inteira — mesmo quando o
      // usuário É o dono. A checagem direta em resource.data.donoUid
      // resolve isso (mesmo padrão já usado abaixo em /membros).
      allow read:   if isDonoDoNegocio(negocioId) || resource.data.donoUid == request.auth.uid;
      allow create: if isSignedIn() && isBarbeiro() && request.resource.data.donoUid == request.auth.uid;
      allow update, delete: if isDonoDoNegocio(negocioId) || resource.data.donoUid == request.auth.uid;

      // Papel e comissão de cada profissional — só o dono acessa.
      // A 2ª condição resolve o "ovo e a galinha" da criação do negócio: o
      // 1º membro (o próprio dono) ainda não existe quando isDonoDoNegocio()
      // seria avaliado, então validamos direto contra negocios/{id}.donoUid.
      match /membros/{membroId} {
        allow read, write: if isDonoDoNegocio(negocioId)
          || (membroId == request.auth.uid
              && get(/databases/$(database)/documents/negocios/$(negocioId)).data.donoUid == request.auth.uid
              && request.resource.data.papel == 'dono');
      }
    }

    // ---- Agendamentos (PRIVADOS: só o cliente dono ou o barbeiro dono) ----
    // Item 9.3: identidade primária por clienteUid (imutável).
    // O email é mantido apenas como fallback para docs antigos.
    match /agendamentos/{id} {
      // `negocioId` é denormalizado do Barbeiro na criação (ver AgendamentoScreen):
      // permite ao dono de uma equipe ver/gerenciar os agendamentos de
      // qualquer profissional do próprio negócio, sem precisar de login
      // separado por profissional.
      allow read: if isSignedIn()
        && (resource.data.clienteUid == request.auth.uid
            || resource.data.cliente == request.auth.token.email
            || resource.data.barbeiroId == request.auth.uid
            || isDonoDoNegocio(resource.data.get('negocioId', null)));

      // Cliente agenda para si mesmo (clienteUid == uid) OU o próprio
      // barbeiro cria um agendamento manual (walk-in, telefonema) em nome de
      // um cliente sem conta no app — nesse caso barbeiroId == uid, e o dono
      // de uma equipe também pode criar em nome de um profissional (negocioId).
      allow create: if isSignedIn()
        && (request.resource.data.clienteUid == request.auth.uid
            || request.resource.data.barbeiroId == request.auth.uid
            || isDonoDoNegocio(request.resource.data.get('negocioId', null)));

      allow update: if isSignedIn()
        && (resource.data.clienteUid == request.auth.uid
            || resource.data.cliente == request.auth.token.email
            || resource.data.barbeiroId == request.auth.uid
            || isDonoDoNegocio(resource.data.get('negocioId', null)));

      allow delete: if isSignedIn()
        && (resource.data.barbeiroId == request.auth.uid
            || isDonoDoNegocio(resource.data.get('negocioId', null)));
    }

    // ---- Ocupação de horários (SEM dados pessoais) ----
    // Usada apenas para o cliente checar quais horários estão livres.
    // Não contém nome/email/telefone — por isso pode ser lida por qualquer logado.
    match /ocupacoes/{slotId} {
      allow read:          if isSignedIn();
      allow create, delete: if isSignedIn();
      allow update:        if false;
    }

    // ---- Avaliações ----
    match /avaliacoes/{id} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.cliente == request.auth.token.email;
      allow update, delete: if false;
    }
  }
}
