# Modelo de credenciais de assinatura do RELEASE.
#
# 1. Copie este arquivo para "keystore.properties" (na pasta android/)
# 2. Preencha com os dados do SEU keystore
# 3. NUNCA versione o keystore.properties nem o .jks (já estão no .gitignore)
#
# Para gerar o keystore, veja ASSINATURA_RELEASE.md na raiz do projeto.

# Caminho do arquivo .jks relativo à pasta android/
storeFile=app/barbershop-release.jks
storePassword=COLOQUE_A_SENHA_DO_KEYSTORE
keyAlias=barbershop
keyPassword=COLOQUE_A_SENHA_DA_CHAVE
